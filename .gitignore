node_modules/
main.js
*.js.map
dist/
data.json
data.json.*
.env
.env.*
.synapse/
.auto-notes/
*.bak
*.tmp

# Secrets / credentials (defense-in-depth: keys live only in Obsidian's
# saveData() / data.json, never committed; these patterns stop any stray
# credential file from being staged accidentally)
secrets.json
credentials.json
*.secret
*.pem
*.key
*.p12
*.pfx
.DS_Store
coverage/
.obsidian/

# Agent / tooling harness artifacts (Claude Code, Codex, etc.)
.claude/worktrees
.claude/settings.local.json
# Project-local private agent definitions (not toolkit-managed)
.claude/agents/brand-manager.md
.claude/agents/product-manager.md
.claude/skills/brand-guidelines
# agent-toolkit renders that embed the account-specific local overlay
# (see .wafflestack.yaml; the rest of the rendered files are committed)
.claude/skills/delegate/
.claude/skills/git-workflow/
.wafflestack.local.yaml
.agents/
.codex/

# Logs
*.log
npm-debug.log*
yarn-error.log*

# Internal Docs
docs/reviews/