{
	"name": "synapse",
	"version": "1.0.4",
	"description": "Automatically elaborate, transcribe, enrich, summarize, organize, and connect your notes with AI.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
