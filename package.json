		"@emnapi/runtime": "^1.7.1",
		"@eslint/js": "^9.39.4",
		"@types/node": "^22.0.0",
		"@vitest/coverage-v8": "^4.1.8",
		"esbuild": "^0.28.1",
		"eslint": "^9.39.4",
		"obsidian": "1.7.2",
		"tslib": "^2.7.0",
		"typescript": "^5.6.0",
		"typescript-eslint": "^8.61.0",
		"vitest": "^4.1.0"
	}
